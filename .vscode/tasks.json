{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      // Forces the task terminal runner to enter the extension sub-folder before triggering tsc
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "problemMatcher": [
        "$tsc"
      ],
      "label": "npm: compile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}